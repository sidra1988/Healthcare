rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Users ---
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL'])
      );

      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'email', 'role']) &&
               data.uid == request.auth.uid &&
               data.email is string &&
               data.role in ['patient', 'doctor', 'admin'];
      }
    }

    // --- Doctors ---
    match /doctors/{doctorId} {
      allow list: if true;
      allow get: if true;
      allow write: if false; // Only admin can edit doctors (manual for now)
    }

    // --- Appointments ---
    match /appointments/{appointmentId} {
      allow list: if isSignedIn() && (
        resource.data.patientId == request.auth.uid
      );
      allow get: if isSignedIn() && (
        resource.data.patientId == request.auth.uid
      );
      allow create: if isSignedIn() && 
                    isValidId(appointmentId) &&
                    isValidAppointment(incoming());
      allow update: if isOwner(existing().patientId) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['status']) &&
        incoming().status in ['cancelled']
      );

      function isValidAppointment(data) {
        return data.keys().hasAll(['patientId', 'doctorId', 'date', 'status', 'createdAt']) &&
               data.patientId == request.auth.uid &&
               data.status == 'scheduled' &&
               data.date is string &&
               data.createdAt == request.time;
      }
    }
  }
}
