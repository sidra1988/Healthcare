{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Patient user profiles",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["patient", "doctor", "admin"] }
      },
      "required": ["uid", "email"]
    },
    "Doctor": {
      "title": "Doctor Profile",
      "description": "Information about medical professionals",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "specialty": { "type": "string" },
        "experience": { "type": "number" },
        "rating": { "type": "number" },
        "bio": { "type": "string" },
        "image": { "type": "string" },
        "department": { "type": "string" }
      },
      "required": ["name", "specialty"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Booked medical appointments",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "patientId": { "type": "string" },
        "doctorId": { "type": "string" },
        "doctorName": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["scheduled", "cancelled", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["patientId", "doctorId", "date", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data"
    },
    "/doctors/{doctorId}": {
      "schema": "Doctor",
      "description": "Doctor directory data"
    },
    "/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Appointment bookings"
    }
  }
}
